<!--pages/home/home.wxml-->
<global-alert />
<swiper indicator-dots circular indicator-color="#ffffff" indicator-active-color="FFC0CB" autoplay interval="2000">
  <swiper-item wx:for="{{swiperList}}" wx:key="*this" bindtap="selectImage" data-index="{{index}}">
    <image src="{{item}}"></image>
    <view class="selection-indicator {{selectedIndex === index ? 'selected' : ''}}">
      <view class="selection-circle"></view>
    </view>
  </swiper-item>
</swiper>
