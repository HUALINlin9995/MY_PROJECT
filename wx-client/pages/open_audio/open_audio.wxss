/* 容器：彻底消除左右内边距，强制占满屏幕宽度 */
.container {
  padding: 20rpx 0 !important;
  margin: 0 !important;
  background: #000000;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  width: 100vw;
  box-sizing: border-box;
}

/* 列表容器：消除所有边距，强制占满宽度 */
.list {
  flex: 1;
  margin: 0 0 140rpx 0 !important;
  padding: 0 16rpx !important;
  width: 100%;
  box-sizing: border-box;
}

/* 音频项：强制占满父容器，增大圆角，两端对齐布局 */
.item {
  background: #302d2d;
  border-radius: 48rpx !important;
  padding: 32rpx 24rpx !important;
  margin: 0 0 20rpx 0 !important;
  display: flex;
  align-items: center;
  /* 核心：两端对齐，删除按钮自动到最右 */
  justify-content: space-between !important;
  box-shadow: 0 8rpx 24rpx rgba(236,45,122,0.4);
  transition: all 0.2s ease;
  width: 100% !important;
  box-sizing: border-box !important;
  position: relative;
  min-height: 160rpx;
}

.item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(236,45,122,0.2);
}

/* 播放按钮：缩小尺寸，固定在左侧 */
.play-btn {
  width: 72rpx;
  height: 72rpx;
  background: #4CAF50;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 0 !important;
  flex-shrink: 0;
}

.play-btn:active {
  background: #45a049;
}

/* 音频信息：占据中间剩余空间 */
.info {
  flex: 1 !important;
  min-width: 0;
  margin: 0 16rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 4rpx;
  overflow: hidden;
  margin: 8rpx 0;
  visibility: visible;
  position: relative;
}

.progress {
  height: 100%;
  background: #ffffff;
  transition: width 0.1s ease;
  border-radius: 4rpx;
}

.time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

/* 删除按钮：固定在最右侧 */
.delete-btn {
  width: 70rpx;
  height: 70rpx;
  background: #ff4444;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
  font-size: 40rpx;
  color: white;
  font-weight: bold;
}

.delete-btn:active {
  background: #e63e3e;
}

.arrow-btn {
  width: 70rpx;
  height: 70rpx;
  background: #4CAF50;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  flex-shrink: 0;
  font-size: 36rpx;
  color: white;
  font-weight: bold;
}

.arrow-btn:active {
  background: #4CAF50;
}

/* 底部上传容器 */
.upload-container {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  z-index: 100;
}

.upload-box {
  background: #FE6672;
  color: white;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  transition: all 0.3s ease;
}

.upload-box:active {
  background: #d6276f;
  transform: scale(0.95);
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
  color: #ffffff;
  margin-top: 100rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  color: #FE6672;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 录音控制面板 */
.record-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.record-panel-content {
  background: #302d2d;
  border-radius: 32rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 500rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(236,45,122,0.4);
}

.record-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 40rpx;
}

.record-time {
  font-size: 48rpx;
  font-weight: bold;
  color: #FE6672;
  margin-bottom: 40rpx;
}

.record-controls {
  margin-bottom: 40rpx;
}

.record-btn, .stop-btn, .play-preview-btn, .send-btn, .close-btn {
  padding: 20rpx 40rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin: 10rpx;
  display: inline-block;
  min-width: 160rpx;
}

.record-btn {
  background: #4CAF50;
  color: white;
}

.stop-btn {
  background: #ff4444;
  color: white;
}

.play-preview-btn {
  background: #2196F3;
  color: white;
}

.send-btn {
  background: #FE6672;
  color: white;
}

.close-btn {
  background: #666666;
  color: white;
  margin-top: 20rpx;
}

.record-preview {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255,255,255,0.3);
}

.preview-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 20rpx;
}

.preview-controls {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}