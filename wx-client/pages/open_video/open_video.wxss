/* pages/open_video/open_video.wxss */
.page-container {
  background-color: #000000;
  min-height: 100vh;
}

.video-list {
  padding: 20rpx;
}

.video-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 30rpx;
  background-color: #1a1a1a;
  border-radius: 12rpx;
  padding: 20rpx;
}

.video-player {
  flex: 1;
  height: 300rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.button-group {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 30rpx;
}

.icon-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.play-btn {
  background-color: #4CAF50;
  box-shadow: 0 10rpx 20rpx rgba(76, 175, 80, 0.6);
}

.play-btn:active {
  opacity: 0.8;
  box-shadow: 0 20rpx 60rpx rgba(76, 175, 80, 0.8);
  transform: scale(0.95);
}

.delete-btn {
  background-color: #F44336;
  box-shadow: 0 10rpx 20rpx rgba(244, 67, 54, 0.6);
}

.delete-btn:active {
  opacity: 0.8;
  box-shadow: 0 20rpx 60rpx rgba(244, 67, 54, 0.8);
  transform: scale(0.95);
}

.btn-text {
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
  line-height: 1;
}

/* 加号按钮样式 */
.add-btn {
  position: fixed;
  bottom: 100rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #F86B1D;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 99;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}

.add-icon {
  color: #fff;
  font-size: 60rpx;
  font-weight: bold;
  line-height: 1;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background-color: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 500rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
}

.picker-container {
  padding: 20rpx;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #f0f0f0;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  border: none;
  padding: 30rpx;
  font-size: 32rpx;
  background-color: transparent;
}

.cancel-btn {
  color: #999;
  border-right: 2rpx solid #f0f0f0;
}

.confirm-btn {
  color: #4CAF50;
  font-weight: bold;
}