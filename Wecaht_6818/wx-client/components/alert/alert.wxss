/* 全局报警框样式 */
.alert-box {
  display: flex;
  align-items: center;
  position: relative;
  background-color: #fff3cd;
  color: #856404;
  padding: 20rpx 60rpx 20rpx 30rpx;
  margin: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid #ffeeba;
  box-sizing: border-box;
}

.alert-icon {
  margin-right: 15rpx;
  font-size: 32rpx;
}

.alert-text {
  flex: 1;
  font-size: 28rpx;
}

.alert-close {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: #856404;
  line-height: 1;
}